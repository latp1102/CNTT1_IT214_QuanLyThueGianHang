datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int            @id @default(autoincrement())
  username     String         @unique
  email        String         @unique
  password     String
  avatar       String?
  status       String         @default("active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  
  userRoles      UserRole[]
  notifications  Notification[]
  logs           Log[]
  files          File[]
  customers      Customer[]
  chatMessages   ChatMessage[]
  videoCallsInitiated   VideoCall[] @relation("VideoCallCaller")
  videoCallsReceived    VideoCall[] @relation("VideoCallReceiver")
  facialId       String?        @db.Text @map("facial_id")

  @@map("users")
}

model Role {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  description  String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  
  userRoles    UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  description  String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Booth {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  area        Float
  price       Float
  floor       Int
  zone        String
  status      String     @default("available")
  description String?    @db.Text
  images      String?    @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  contracts   Contract[]

  @@map("booths")
}

model Customer {
  id        Int        @id @default(autoincrement())
  userId    Int?       @unique @map("user_id")
  name      String
  email     String     @unique
  phone     String
  idCard    String     @map("id_card")
  company   String?
  address   String?
  avatar    String?
  status    String     @default("active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  contracts Contract[]
  images    CustomerImage[]

  @@map("customers")
}

model CustomerImage {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  imageUrl   String   @map("image_url")
  caption    String?
  createdAt  DateTime @default(now()) @map("created_at")

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_images")
}

model Contract {
  id           Int        @id @default(autoincrement())
  contractCode String     @unique @map("contract_code")
  boothId      Int        @map("booth_id")
  customerId   Int        @map("customer_id")
  deposit      Float
  startDate    DateTime   @map("start_date")
  endDate      DateTime   @map("end_date")
  status       String     @default("active")
  pdfUrl       String?    @map("pdf_url")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  booth        Booth      @relation(fields: [boothId], references: [id], onDelete: Restrict)
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  payments     Payment[]
  invoices     Invoice[]

  @@map("contracts")
}

model Payment {
  id            Int      @id @default(autoincrement())
  paymentCode   String   @unique @map("payment_code")
  contractId    Int      @map("contract_id")
  invoiceId     Int?     @map("invoice_id")
  amount        Float
  paymentMethod String   @map("payment_method")
  paymentDate   DateTime @default(now()) @map("payment_date")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  invoice       Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@map("payments")
}

model Invoice {
  id          Int       @id @default(autoincrement())
  invoiceCode String    @unique @map("invoice_code")
  contractId  Int       @map("contract_id")
  title       String
  description String?   @db.Text
  amount      Float
  dueDate     DateTime  @map("due_date")
  status      String    @default("unpaid")
  pdfUrl      String?   @map("pdf_url")
  excelUrl    String?   @map("excel_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@map("invoices")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  title     String
  content   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  type      String   @default("info")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model File {
  id         Int      @id @default(autoincrement())
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  fileType   String   @map("file_type")
  size       Int
  uploaderId Int?     @map("uploader_id")
  createdAt  DateTime @default(now()) @map("created_at")

  uploader   User?    @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@map("files")
}

model Log {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("logs")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  role      String   // "user" or "bot"
  content   String   @db.Text
  sessionId String?  @map("session_id") // Group messages by session
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}

model VideoCall {
  id           Int      @id @default(autoincrement())
  callerId     Int      @map("caller_id")
  receiverId   Int      @map("receiver_id")
  status       String   @default("missed") // "completed", "missed", "rejected"
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")
  duration     Int?     // seconds
  createdAt    DateTime @default(now()) @map("created_at")

  caller       User     @relation("VideoCallCaller", fields: [callerId], references: [id], onDelete: Cascade)
  receiver     User     @relation("VideoCallReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("video_calls")
}
